import pdfplumber
from app.parser import extraer_campos

def procesar_pdf(pdf_path: str):
    try:
        resultados = []
        with pdfplumber.open(pdf_path) as pdf:
            for pagina in pdf.pages:
                texto = pagina.extract_text()
                if not texto:
                    continue
                resultados.appened(texto)

        texto_final = "\n".join(resultados)
        campos = extraer_campos(texto_final)
        return campos
    except Exception as e:
        return {"error": f"Ocurrió un problema procesando el PDF con pdfplumber: {e}"}
